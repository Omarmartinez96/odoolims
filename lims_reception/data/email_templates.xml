<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>
    <record id="email_template_comprobante" model="mail.template">
      <field name="name">Comprobante de Cadena de Custodia</field>
      <field name="model_id" model="ir.model" search="[('model','=','lims.custody_chain')]"/>
      <!-- Adjunta el PDF generado por la acción de reporte -->
      <field name="email_from">${'"Lab. Proteus - Cadena de Custodia %s" &lt;no-responder@proteuslaboratorio.com&gt;' % (object.custody_chain_code or '')}</field>
      <field name="email_to">${object.cliente_id.email or ''}</field>
      <field name="subject">Comprobante de Cadena de Custodia - ${object.custody_chain_code}</field>
      <field name="body_html"><![CDATA[
        <p><strong style="color: #1a1a1a;">Estimado/a Cliente,</strong></p>
        <p>En este correo encontrará adjunto el comprobante de cadena de custodia de las muestras:</p>
        <p><strong>Cadena de Custodia:</strong> ${object.custody_chain_code}</p>
        <p>Gracias por su confianza.</p>
        <br/>
        <p>Atentamente,<br/>El equipo de ${user.company_id.name}</p>
        <br/>
        <p style="font-style: italic; font-size: 12px; color: #555555; border-left: 3px solid #cccccc; padding: 6px 12px;">
          "Este correo es generado automáticamente. Favor de no responder directamente a este mensaje.
          Para dudas o consultas, contáctenos en
          <a href="mailto:contacto@proteuslaboratorio.com" style="color: #555555;">contacto@proteuslaboratorio.com</a>
          o a través de cualquier medio de contacto autorizado."
        </p>
      ]]></field>
    </record>
  </data>
</odoo>