<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================================================================
         WEBSITE PAGES - Registro de páginas para el website builder
         La página se publica en /inicio para no conflictuar con el
         homepage existente. El administrador puede configurar la
         página de inicio desde Sitio Web > Configuración > Páginas.
    =================================================================== -->

    <record id="lims_website_homepage_page" model="website.page">
        <field name="view_id" ref="lims_homepage_view"/>
        <field name="url">/inicio</field>
        <field name="website_published">True</field>
        <field name="is_homepage">True</field>
    </record>


</odoo>
