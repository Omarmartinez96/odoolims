<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================================================================
         WEBSITE PAGES - Registro de páginas para el website builder
         La página se publica en /inicio para no conflictuar con el
         homepage existente. El administrador puede configurar la
         página de inicio desde Sitio Web > Configuración > Páginas.
    =================================================================== -->

    <record id="lims_website_homepage_page" model="website.page">
        <field name="view_id" ref="lims_homepage_view"/>
        <field name="url">/inicio</field>
        <field name="website_published">True</field>
        <field name="is_homepage">True</field>
    </record>

    <record id="menu_contacto_comercial" model="website.menu">
        <field name="name">Contacto Comercial</field>
        <field name="url">/contacto-comercial</field>
        <field name="parent_id" eval="ref('website.main_menu')"/>
        <field name="sequence">10</field>
        <field name="website_id" eval="ref('website.default_website')"/>
    </record>

    <record id="menu_sugerencias_quejas" model="website.menu">
        <field name="name">Sugerencias y Quejas</field>
        <field name="url">/sugerencias-quejas</field>
        <field name="parent_id" eval="ref('website.main_menu')"/>
        <field name="sequence">20</field>
        <field name="website_id" eval="ref('website.default_website')"/>
    </record>

    <!-- ===================================================================
         NOTA SOBRE MENÚS:
         Los ítems de menú se gestionan desde el editor del sitio web
         (Sitio Web > Editor > Menú) para evitar conflictos con el menú
         existente. Rutas disponibles:
           /inicio              → Página de inicio del portal
           /contacto-comercial  → Formulario de contacto comercial
           /sugerencias-quejas  → Formulario de sugerencias y quejas
    =================================================================== -->

</odoo>
