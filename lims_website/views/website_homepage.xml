<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================================================================
         HOMEPAGE - Página principal del portal de Laboratorio Proteus
    =================================================================== -->
    <record id="lims_homepage_view" model="ir.ui.view">
        <field name="name">Inicio | Laboratorio de Microbiología Proteus</field>
        <field name="type">qweb</field>
        <field name="key">lims_website.homepage</field>
        <field name="arch" type="xml">
            <t t-name="lims_website.homepage">
                <t t-call="website.layout">
                    <t t-set="pageName" t-value="'homepage'"/>
                    <t t-set="no_header_seotitle" t-value="True"/>
                    <t t-set="website_title" t-value="'Inicio | Laboratorio de Microbiología Proteus'"/>

                    <!-- ================================================
                         HERO SECTION
                    ================================================ -->
                    <section class="lims-hero">
                        <div class="lims-hero-overlay"/>
                        <div class="container lims-hero-content">
                            <div class="row justify-content-center">
                                <div class="col-lg-9 col-md-11 text-center">
                                    <span class="lims-hero-badge">
                                        <i class="fa fa-flask me-2"/>Laboratorio de Análisis Certificado
                                    </span>
                                    <h1 class="lims-hero-title">Laboratorio de Microbiología Proteus</h1>
                                    <p class="lims-hero-tagline">
                                        Soluciones analíticas precisas y confiables para empresas, industrias y profesionales de la salud
                                    </p>
                                    <div class="lims-hero-portals">
                                        <a href="/web/login?redirect=/my"
                                           class="lims-btn-portal lims-btn-portal--client">
                                            <i class="fa fa-sign-in me-2"/>
                                            Acceder al Portal
                                        </a>
                                    </div>
                                    <p class="lims-hero-hint">
                                        <i class="fa fa-info-circle me-1"/>
                                        ¿Primera vez? Solicita tu acceso escribiéndonos a
                                        <a href="mailto:contacto@proteuslaboratorio.com" class="lims-hero-link">
                                            contacto@proteuslaboratorio.com
                                        </a>
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="lims-hero-wave">
                            <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#edf2f9"/>
                            </svg>
                        </div>
                    </section>

                    <!-- ================================================
                         PORTAL ACCESS CARD (single, centered)
                    ================================================ -->
                    <section class="lims-portals-section">
                        <div class="container">
                            <div class="text-center mb-5">
                                <h2 class="lims-section-title">Portal de Clientes</h2>
                                <p class="lims-section-subtitle">
                                    Accede a tus resultados, reportes y seguimiento de muestras de forma segura
                                </p>
                            </div>
                            <div class="row justify-content-center">
                                <div class="col-lg-7 col-md-9">
                                    <div class="lims-portal-card lims-portal-card--client lims-portal-card--centered">
                                        <div class="lims-portal-card__icon">
                                            <i class="fa fa-flask fa-2x"/>
                                        </div>
                                        <h3>Acceso al Portal</h3>
                                        <p>Consulta el estado de tus análisis, descarga tus reportes y gestiona tu historial de muestras desde cualquier lugar y dispositivo.</p>
                                        <div class="row g-2 lims-portal-card__features-grid">
                                            <div class="col-sm-6">
                                                <ul class="lims-portal-card__features">
                                                    <li><i class="fa fa-check-circle"/> Resultados de análisis en línea</li>
                                                    <li><i class="fa fa-check-circle"/> Descarga de reportes e informes</li>
                                                    <li><i class="fa fa-check-circle"/> Seguimiento de muestras en tiempo real</li>
                                                </ul>
                                            </div>
                                            <div class="col-sm-6">
                                                <ul class="lims-portal-card__features">
                                                    <li><i class="fa fa-check-circle"/> Historial completo de servicios</li>
                                                    <li><i class="fa fa-check-circle"/> Facturas y documentos fiscales</li>
                                                    <li><i class="fa fa-check-circle"/> Atención y soporte en línea</li>
                                                </ul>
                                            </div>
                                        </div>
                                        <a href="/web/login?redirect=/my" class="lims-portal-card__btn lims-portal-card__btn--lg">
                                            <i class="fa fa-sign-in me-2"/>Ingresar al Portal
                                        </a>
                                        <p class="lims-portal-card__hint">
                                            ¿Aún no tienes cuenta?
                                            <a href="/contacto-comercial">Solicita tu acceso aquí</a>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- ================================================
                         CONTACT CTA SECTION
                    ================================================ -->
                    <section class="lims-cta-section">
                        <div class="container">
                            <div class="text-center mb-5">
                                <h2 class="lims-section-title">¿Cómo podemos ayudarte?</h2>
                                <p class="lims-section-subtitle">Estamos aquí para atender tus necesidades</p>
                            </div>
                            <div class="row g-4 justify-content-center">
                                <div class="col-lg-5 col-md-6">
                                    <div class="lims-cta-card lims-cta-card--sales">
                                        <div class="lims-cta-card__icon">
                                            <i class="fa fa-handshake-o fa-2x"/>
                                        </div>
                                        <h3>Contacto Comercial</h3>
                                        <p>¿Interesado en contratar nuestros servicios? Déjanos tus datos y un asesor especializado te contactará a la brevedad.</p>
                                        <ul class="lims-cta-card__list">
                                            <li><i class="fa fa-check"/> Cotizaciones personalizadas</li>
                                            <li><i class="fa fa-check"/> Información de servicios</li>
                                            <li><i class="fa fa-check"/> Convenios empresariales</li>
                                        </ul>
                                        <a href="/contacto-comercial" class="lims-cta-card__btn lims-cta-card__btn--primary">
                                            <i class="fa fa-envelope me-2"/>Contactar Ventas
                                        </a>
                                    </div>
                                </div>
                                <div class="col-lg-5 col-md-6">
                                    <div class="lims-cta-card lims-cta-card--feedback">
                                        <div class="lims-cta-card__icon">
                                            <i class="fa fa-comments-o fa-2x"/>
                                        </div>
                                        <h3>Sugerencias y Quejas</h3>
                                        <p>Tu opinión es fundamental para mejorar nuestros servicios. Comparte tu experiencia y trabajaremos para superarla.</p>
                                        <ul class="lims-cta-card__list">
                                            <li><i class="fa fa-check"/> Reportar inconvenientes</li>
                                            <li><i class="fa fa-check"/> Enviar sugerencias</li>
                                            <li><i class="fa fa-check"/> Compartir felicitaciones</li>
                                        </ul>
                                        <a href="/sugerencias-quejas" class="lims-cta-card__btn lims-cta-card__btn--secondary">
                                            <i class="fa fa-paper-plane me-2"/>Enviar Comentarios
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- ================================================
                         CONTACT INFO FOOTER BAR
                    ================================================ -->
                    <section class="lims-info-bar">
                        <div class="container">
                            <div class="row g-3 justify-content-center text-center">
                                <div class="col-lg-3 col-sm-6">
                                    <div class="lims-info-bar__item">
                                        <i class="fa fa-map-marker fa-lg me-2"/>
                                        <span>Defensores de BC 2163 5A, Tijuana, B.C.</span>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-sm-6">
                                    <div class="lims-info-bar__item">
                                        <i class="fa fa-phone fa-lg me-2"/>
                                        <a href="tel:+526649738185">(664) 973 8185</a>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-sm-6">
                                    <div class="lims-info-bar__item">
                                        <i class="fa fa-envelope fa-lg me-2"/>
                                        <a href="mailto:contacto@proteuslaboratorio.com">contacto@proteuslaboratorio.com</a>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-sm-6">
                                    <div class="lims-info-bar__item">
                                        <i class="fa fa-clock-o fa-lg me-2"/>
                                        <span>Lun – Vie: 9:00 – 18:00</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                </t>
            </t>
        </field>
    </record>

</odoo>
