<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_move_form_lims" model="ir.ui.view">
    <field name="name">account.move.form.lims</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">
      
      <!-- Hacer editable el campo "name" en facturas -->
      <xpath expr="//field[@name='name']" position="attributes">
        <attribute name="readonly">0</attribute>
        <attribute name="readonly">state != 'draft'</attribute>
      </xpath>

      <xpath expr="//header" position="inside">
        <!-- Solo visible en facturas PPD con saldo pendiente -->
        <button name="action_open_payment_wizard"
                type="object"
                string="Complemento PPD"
                class="btn-primary"
                invisible="move_type != 'out_invoice' or state != 'posted' or payment_state not in ('not_paid', 'partial')"/>
        <!-- Visible cuando ya hay al menos un pago registrado -->
        <button name="action_download_complemento"
                type="object"
                string="Descargar Complemento"
                class="btn-secondary"
                invisible="move_type != 'out_invoice' or state != 'posted' or payment_state not in ('in_payment', 'partial', 'paid')"/>
      </xpath>

    </field>
  </record>
</odoo>