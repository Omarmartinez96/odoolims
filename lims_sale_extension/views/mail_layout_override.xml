<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!--
    Elimina el footer "Sent with the technology of Odoo" que Odoo agrega
    automáticamente a TODOS los correos salientes a través del layout de notificación.
    Esto no se puede quitar desde el template del correo — está en el wrapper del layout.
  -->
  <template id="lims_mail_notification_layout_no_odoo_footer"
            inherit_id="mail.mail_notification_layout"
            name="LIMS - Sin footer de Odoo">
    <xpath expr="//a[contains(@href, 'odoo.com')]" position="replace"/>
  </template>
</odoo>
